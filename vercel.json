{
  "framework": null,
  "buildCommand": "echo 'static'",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/resume-trigger",
      "schedule": "0 14 * * *"
    }
  ]
}
